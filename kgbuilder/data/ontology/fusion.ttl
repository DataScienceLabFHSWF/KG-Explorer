fusionkg:produces a owl:ObjectProperty ;
    rdfs:label "produces" ;
    fusionkg:neo4jRelType "PRODUCES" ;
    rdfs:comment "Subject generates or emits the object as an output (e.g. D-T reaction produces neutrons)." ;
    rdfs:domain fusionkg:Entity ;
    rdfs:range fusionkg:Entity ;
    rdfs:subPropertyOf fusionkg:typedRelation .

fusionkg:requires a owl:ObjectProperty ;
