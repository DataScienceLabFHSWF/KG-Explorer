    rdfs:subPropertyOf fusionkg:coOccursWith .

fusionkg:comparesTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "compares to" ;
    fusionkg:neo4jRelType "COMPARES_TO" ;
    rdfs:comment "Subject is scientifically compared against the object. Symmetric." ;
    rdfs:domain fusionkg:Entity ;
    rdfs:range fusionkg:Entity ;
    rdfs:subPropertyOf fusionkg:typedRelation .

fusionkg:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    fusionkg:neo4jRelType "CONTAINS" ;
    rdfs:comment "Subject physically or conceptually contains the object (e.g. a tokamak contains plasma)." ;
    rdfs:domain fusionkg:Entity ;
    rdfs:range fusionkg:Entity ;
    rdfs:subPropertyOf fusionkg:typedRelation .

fusionkg:improves a owl:ObjectProperty ;
    rdfs:label "improves" ;
    fusionkg:neo4jRelType "IMPROVES" ;
    rdfs:comment "Subject enhances the performance or quality of the object." ;
    rdfs:domain fusionkg:Entity ;
    rdfs:range fusionkg:Entity ;
    rdfs:subPropertyOf fusionkg:typedRelation .

fusionkg:isTypeOf a owl:ObjectProperty ;
    rdfs:label "is type of" ;
    fusionkg:neo4jRelType "IS_TYPE_OF" ;
    rdfs:comment "Subject is a specific instance or sub-type of the object (e.g. ITER is type of Tokamak)." ;
    rdfs:domain fusionkg:Entity ;
    rdfs:range fusionkg:Entity ;
    rdfs:subPropertyOf fusionkg:typedRelation .

fusionkg:mentionCount a owl:DatatypeProperty ;
    rdfs:label "mention count" ;
    rdfs:domain fusionkg:Entity ;
