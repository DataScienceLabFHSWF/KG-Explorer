{
  "domain": "fusion-energy",
  "description": "Nuclear fusion energy research — tokamaks, stellarators, plasma physics, ICF",

  "llm": {
    "model": "gemma4:e2b",
    "base_url": "http://localhost:11434",
    "temperature": 0.0,
    "max_tokens": 2048,
    "structured_output": true
  },

  "embedding": {
    "model": "nomic-embed-text",
    "base_url": "http://localhost:11434",
    "dimensions": 384
  },

  "neo4j": {
    "uri": "bolt://localhost:7687",
    "user": "neo4j",
    "password": "fusion2026",
    "database": "neo4j",
    "graph_type": "fusion-energy"
  },

  "qdrant": {
    "url": "http://localhost:6333",
    "collection": "fusion-energy-chunks"
  },

  "fuseki": {
    "url": "http://localhost:3030",
    "dataset": "fusion-ontology"
  },

  "pipeline": {
    "max_iterations": 3,
    "questions_per_class": 4,
    "confidence_threshold": 0.5,
    "top_k": 10,
    "chunk_size": 512,
    "chunk_overlap": 64,
    "chunking_strategy": "sentence",
    "extensions": [".pdf", ".txt", ".md"]
  },

  "extraction": {
    "min_entity_confidence": 0.5,
    "min_relation_confidence": 0.45,
    "enable_rule_based": true,
    "enable_coreference": true,
    "enable_source_alignment": true,
    "cache_llm_responses": true
  },

  "enrichment": {
    "enable_descriptions": true,
    "enable_embeddings": true,
    "enable_competency_questions": true,
    "enable_type_constraints": true,
    "enable_aliases": true
  },

  "validation": {
    "enable_shacl": true,
    "enable_rules_engine": true,
    "enable_consistency_check": true,
    "enable_static_validation": false
  },

  "analytics": {
    "enable_owl_rl_inference": true,
    "enable_skos_enrichment": true,
    "enable_graph_metrics": true
  },

  "output": {
    "directory": "output/kgbuilder_output",
    "formats": ["json-ld", "turtle", "cypher", "graphml"],
    "save_checkpoint": true
  },

  "notes": [
    "Ollama runs locally on host (not in Docker), so base_url uses localhost.",
    "Neo4j shares the same instance as the KG-explorer project.",
    "KGB writes to graph_type='fusion-energy' to keep its nodes distinct.",
    "After KGB completes, run analysis/typed_relation_ie.py --commit to upgrade CO_OCCURS_WITH edges.",
    "The ontology file should be output/fusion_ontology.ttl (generated by analysis/ontology_generator.py)."
  ]
}
